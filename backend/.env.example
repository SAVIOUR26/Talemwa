# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# ── App Identity ──────────────────────────────────────────────────────────────
APP_NAME=Talemwa
APP_URL=https://roberttalemwa.online
ADMIN_URL=https://admin.roberttalemwa.online
API_URL=https://api.roberttalemwa.online

# ── Firebase (FCM Push Notifications) ────────────────────────────────────────
# Firebase Console → Project Settings → Cloud Messaging → Server Key
FCM_SERVER_KEY=REPLACE_WITH_FCM_SERVER_KEY

# ── Radio ─────────────────────────────────────────────────────────────────────
# Demo / pre-launch: point STREAM_URL at a free hosted stream (e.g. Zeno.fm)
# and leave AZURACAST_URL blank — the API serves it directly with no "now
# playing" metadata.
STREAM_URL=https://stream.zeno.fm/REPLACE_WITH_ZENO_STREAM_ID
AZURACAST_URL=
AZURACAST_STATION=1
# Once a VPS is provisioned for AzuraCast (deploy/scripts/azuracast-setup.sh),
# set these and STREAM_URL=https://radio.roberttalemwa.online/stream
# AzuraCast Admin Panel → Admin → API Keys → Generate
AZURACAST_API_KEY=

# ── Payments: Flutterwave (Uganda / Africa) ───────────────────────────────────
# Flutterwave Dashboard → Settings → API Keys
FLUTTERWAVE_PUBLIC_KEY=REPLACE_WITH_FLW_PUBLIC_KEY
FLUTTERWAVE_SECRET_KEY=REPLACE_WITH_FLW_SECRET_KEY
FLUTTERWAVE_ENCRYPTION_KEY=REPLACE_WITH_FLW_ENCRYPTION_KEY

# ── Payments: PayPal (Diaspora) ───────────────────────────────────────────────
PAYPAL_CLIENT_ID=REPLACE_WITH_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=live
# sandbox | live  — use sandbox for testing, live for production

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_PATH=/var/www/talemwa/backend/uploads/sermons/
MAX_UPLOAD_MB=200
