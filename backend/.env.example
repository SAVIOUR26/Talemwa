# ── Security ──────────────────────────────────────
JWT_SECRET=change-this-to-a-64-char-random-string

# ── Firebase (FCM Push Notifications) ─────────────
FCM_SERVER_KEY=your-firebase-server-key-here

# ── Radio (AzuraCast) ─────────────────────────────
STREAM_URL=https://radio.roberttalemwa.online/stream
AZURACAST_URL=https://radio.roberttalemwa.online
AZURACAST_STATION=1
AZURACAST_API_KEY=your-azuracast-api-key

# ── Payments ──────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_ENCRYPTION_KEY=your-flutterwave-encryption-key
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# ── App ───────────────────────────────────────────
APP_NAME=Talemwa
APP_URL=https://roberttalemwa.online
ADMIN_URL=https://admin.roberttalemwa.online
API_URL=https://api.roberttalemwa.online

# ── Storage ───────────────────────────────────────
UPLOAD_PATH=uploads/sermons/
MAX_UPLOAD_MB=200
